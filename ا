TOTAL_MARKS = sum(q["marks"] for q in QUESTIONS)

# ── Session state ─────────────────────────────────────────────────────────────
for key in ("results", "hints", "solutions"):
    if key not in st.session_state:
        st.session_state[key] = {}

# ── Page config ───────────────────────────────────────────────────────────────
st.set_page_config(
    page_title="Functions Quiz | Cambridge AS Level",
    page_icon="📐",
    layout="centered",
)

# ── Header ────────────────────────────────────────────────────────────────────
st.markdown(
    """
    <div style="background:#1B2A4A;padding:1.5rem 2rem;border-radius:10px;margin-bottom:1rem">
      <h2 style="color:#F4C430;margin:0">📐 Functions – Interactive Quiz</h2>
      <p style="color:#9EC8D4;margin:0.3rem 0 0">
        Cambridge AS & A Level Mathematics 9709 &nbsp;·&nbsp; Pure Mathematics 1 &nbsp;·&nbsp; Section 1.2
      </p>
    </div>
    """,
    unsafe_allow_html=True,
)

# ── Instructions ──────────────────────────────────────────────────────────────
with st.expander("📋 Instructions", expanded=False):
    st.markdown(
        """
        - Type your answer in the input box below each question.
        - For **numerical** answers, type a number, e.g. `7` or `-4`.
        - For **algebraic** answers, type an expression using standard notation:
          - Use `^` or `**` for powers: `x^2` or `x**2`
          - Use `/` for fractions: `(x+2)/5`
          - Use `sqrt(...)` for square roots: `sqrt(x-5) + 2`
        - Click **Check ✔** to mark your answer.
        - Click **Hint 💡** if you're stuck (this won't affect your score).
        - Click **Show Solution 📖** after attempting a question.
        """
    )

# ── Live score bar ────────────────────────────────────────────────────────────
score = sum(v["marks"] for v in st.session_state.results.values() if v["correct"])
attempted = len(st.session_state.results)
pct = score / TOTAL_MARKS if TOTAL_MARKS > 0 else 0

c1, c2, c3 = st.columns(3)
c1.metric("Score", f"{score} / {TOTAL_MARKS}")
c2.metric("Attempted", f"{attempted} / {len(QUESTIONS)}")
c3.metric("Percentage", f"{int(pct * 100)}%")
st.progress(pct)
st.markdown("---")

# ── Render questions ──────────────────────────────────────────────────────────
for q in QUESTIONS:
    qid = q["qid"]
    result = st.session_state.results.get(qid)

    with st.container():
        # Question header
        h1, h2 = st.columns([5, 1])
        with h1:
            st.markdown(f"**Q{qid}** &nbsp; _{q['topic']}_")
        with h2:
            badge = f"[{q['marks']} mk]"
            st.markdown(
                f"<div style='text-align:right;color:#888'><b>{badge}</b></div>",
                unsafe_allow_html=True,
            )

        # Question text (LaTeX rendered via st.markdown)
        st.markdown(q["latex"])

        # Answer input
        already_correct = result is not None and result["correct"]
        user_ans = st.text_input(
            "Answer:",
            key=f"input_{qid}",
            placeholder="Type answer here…",
            disabled=already_correct,
        )

        # Buttons
        b1, b2, b3 = st.columns([1, 1, 2])
        with b1:
            check_clicked = st.button("Check ✔", key=f"check_{qid}", disabled=already_correct)
        with b2:
            hint_clicked = st.button("Hint 💡", key=f"hint_{qid}")
        with b3:
            sol_clicked = (
                st.button("Show Solution 📖", key=f"sol_{qid}")
                if result is not None
                else False
            )

        # ── Check answer ──────────────────────────────────────────────────────
        if check_clicked and user_ans.strip():
            if q["type"] == "numeric":
                correct = numeric_match(user_ans, q["answer"])
            else:
                correct = algebraic_match(user_ans, q["answer"])
            st.session_state.results[qid] = {
                "answer": user_ans,
                "correct": correct,
                "marks": q["marks"] if correct else 0,
            }
            st.rerun()

        # ── Feedback ──────────────────────────────────────────────────────────
        if result is not None:
            if result["correct"]:
                st.success(
                    f"✅ Correct! +{q['marks']} mark{'s' if q['marks'] > 1 else ''}"
                )
            else:
                st.error("❌ Not quite — check your working, use a hint, or review the solution.")

        # ── Hint ──────────────────────────────────────────────────────────────
        if hint_clicked:
            st.session_state.hints[qid] = True
        if st.session_state.hints.get(qid):
            st.info(f"💡 **Hint:** {q['hint']}")

        # ── Solution ──────────────────────────────────────────────────────────
        if sol_clicked:
            st.session_state.solutions[qid] = True
        if st.session_state.solutions.get(qid):
            st.markdown(f"📖 **Solution:** &nbsp; {q['solution']}")

        st.markdown("---")

# ── Final score panel ─────────────────────────────────────────────────────────
if attempted == len(QUESTIONS):
    pct_final = int(100 * score / TOTAL_MARKS)
    st.markdown("### 🎯 Quiz Complete!")

    if pct_final == 100:
        st.balloons()
        st.success(f"🎉 Full marks! {score}/{TOTAL_MARKS} — Outstanding performance.")
    elif pct_final >= 70:
        st.success(f"👍 {score}/{TOTAL_MARKS} ({pct_final}%) — Strong result. Review any mistakes.")
    elif pct_final >= 50:
        st.warning(f"📚 {score}/{TOTAL_MARKS} ({pct_final}%) — Good effort. Revisit composite and inverse functions.")
    else:
        st.error(f"💪 {score}/{TOTAL_MARKS} ({pct_final}%) — Keep practising! Review Section 1.2 notes.")

    st.markdown("---")
    if st.button("🔄 Reset and Try Again"):
        for key in ("results", "hints", "solutions"):
            st.session_state[key] = {}
        st.rerun()
