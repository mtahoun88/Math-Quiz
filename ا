import streamlit as st
from sympy import symbols, simplify
from sympy.parsing.sympy_parser import (
    parse_expr,
    standard_transformations,
    implicit_multiplication_application,
)

# ── Sympy helpers ─────────────────────────────────────────────────────────────
x = symbols("x")
_TR = standard_transformations + (implicit_multiplication_application,)


def _to_expr(s: str):
    try:
        return parse_expr(s.strip().replace("^", "**"), transformations=_TR)
    except Exception:
        return None


def algebraic_match(student: str, correct: str) -> bool:
    a, b = _to_expr(student), _to_expr(correct)
    if a is None or b is None:
        return False
    return simplify(a - b) == 0


def numeric_match(student: str, correct: float) -> bool:
    try:
        return abs(float(student.strip()) - correct) < 1e-9
    except Exception:
        return False


